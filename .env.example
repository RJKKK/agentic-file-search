# OpenAI-compatible text model for agent planning / structured reasoning
TEXT_MODEL_NAME=gpt-4o-mini
TEXT_API_KEY=your_text_model_api_key_here
# TEXT_BASE_URL=https://your-openai-compatible-endpoint/v1

# OpenAI-compatible vision model for lazy image semantic enhancement
VISION_MODEL_NAME=gpt-4o-mini
# VISION_API_KEY=your_vision_model_api_key_here
# VISION_BASE_URL=https://your-openai-compatible-endpoint/v1

# OpenAI-compatible embedding model for semantic retrieval
EMBEDDING_MODEL_NAME=text-embedding-3-small
# EMBEDDING_API_KEY=your_embedding_model_api_key_here
# EMBEDDING_BASE_URL=https://your-openai-compatible-endpoint/v1
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=50

# Optional: override the metadata/langextract model separately.
# Defaults to TEXT_* when omitted.
# LANGEXTRACT_MODEL_NAME=gpt-4o-mini
# LANGEXTRACT_API_KEY=your_langextract_api_key_here
# LANGEXTRACT_BASE_URL=https://your-openai-compatible-endpoint/v1

# PostgreSQL DSN for index storage (pgvector-enabled DB recommended).
FS_EXPLORER_DB_DSN=postgresql://fs_explorer:devpassword@127.0.0.1:5432/fs_explorer

# Optional: context-budget hard cap for agent input.
FS_EXPLORER_MAX_INPUT_TOKENS=12000

# Optional: metadata extraction truncation cap.
FS_EXPLORER_LANGEXTRACT_MAX_CHARS=6000

# Optional: cost hints used only for reporting.
# TEXT_INPUT_COST_PER_MILLION=0
# TEXT_OUTPUT_COST_PER_MILLION=0

# Legacy compatibility only; prefer TEXT_API_KEY / VISION_API_KEY / EMBEDDING_API_KEY.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# GOOGLE_API_KEY=
