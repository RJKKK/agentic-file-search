# Google Gemini API Key
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# PostgreSQL DSN for index storage (pgvector-enabled DB recommended).
# Default in code:
# postgresql://fs_explorer:devpassword@127.0.0.1:5432/fs_explorer
FS_EXPLORER_DB_DSN=postgresql://fs_explorer:devpassword@127.0.0.1:5432/fs_explorer

# Backward-compatible alias (prefer FS_EXPLORER_DB_DSN).
# FS_EXPLORER_DB_PATH=postgresql://fs_explorer:devpassword@127.0.0.1:5432/fs_explorer

# Optional: dedicated key for langextract metadata mode.
# If unset, indexing will fall back to GOOGLE_API_KEY.
# LANGEXTRACT_API_KEY=your_api_key_here

# Optional: override langextract model used by `explore index --with-metadata`.
# FS_EXPLORER_LANGEXTRACT_MODEL=gemini-3-flash-preview
