# App server
FS_EXPLORER_HOST=0.0.0.0
FS_EXPLORER_PORT=8000
FS_EXPLORER_PYTHON_BIN=/opt/venv/bin/python

# Text model
TEXT_MODEL_NAME=gpt-4o-mini
TEXT_API_KEY=your_text_model_api_key_here
# TEXT_BASE_URL=https://your-openai-compatible-endpoint/v1

# Vision model
VISION_MODEL_NAME=gpt-4o-mini
# VISION_API_KEY=your_vision_model_api_key_here
# VISION_BASE_URL=https://your-openai-compatible-endpoint/v1

# Embedding model
EMBEDDING_MODEL_NAME=text-embedding-3-small
# EMBEDDING_API_KEY=your_embedding_model_api_key_here
# EMBEDDING_BASE_URL=https://your-openai-compatible-endpoint/v1
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=50
# EMBEDDING_MODEL_MAX_TOKENS=3072
# EMBEDDING_MODEL_CHAR_BUDGET_RATIO=2
# EMBEDDING_IMAGE_NEIGHBOR_MAX_CHARS=1600

# Traditional RAG
VISION_MAX_SEMANTIC_PER_PAGE=3
VISION_MAX_SEMANTIC_PER_DOC=50
TRADITIONAL_RAG_SMALL_CHUNK_MAX_CHARS=349
TRADITIONAL_RAG_NORMAL_CHUNK_MAX_CHARS=1800
TRADITIONAL_RAG_EVIDENCE_CHAR_BUDGET=12000

# Qdrant
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
