{
  "name": "agentic-file-search-node",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "tsx ./src/server/main.ts",
    "dev": "tsx watch ./src/server/main.ts",
    "frontend:build": "npm --prefix ./frontend run build",
    "frontend:dev": "npm --prefix ./frontend run dev",
    "test": "node --import tsx --test ./tests/agent.test.ts ./tests/blob-store.test.ts ./tests/document-library-service.test.ts ./tests/document-library.test.ts ./tests/document-parsing.test.ts ./tests/explore-sessions.test.ts ./tests/exploration-workflow.test.ts ./tests/http-server.test.ts ./tests/index-search.test.ts ./tests/loader.test.ts ./tests/openai-compatible-model.test.ts ./tests/page-store.test.ts ./tests/prompt.test.ts ./tests/references.test.ts ./tests/sqlite-storage.test.ts",
    "test:watch": "node --import tsx --test --watch ./tests/agent.test.ts ./tests/blob-store.test.ts ./tests/document-library-service.test.ts ./tests/document-library.test.ts ./tests/document-parsing.test.ts ./tests/explore-sessions.test.ts ./tests/exploration-workflow.test.ts ./tests/http-server.test.ts ./tests/index-search.test.ts ./tests/loader.test.ts ./tests/openai-compatible-model.test.ts ./tests/page-store.test.ts ./tests/prompt.test.ts ./tests/references.test.ts ./tests/sqlite-storage.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.9.0",
    "fast-glob": "^3.3.3",
    "fastify": "^5.8.5",
    "iconv-lite": "^0.6.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.16.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
